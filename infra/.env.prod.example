# ── Infra passwords (generate with: openssl rand -hex 24) ─────────────────────
POSTGRES_PASSWORD=FILL_ME
REDIS_PASSWORD=FILL_ME

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=8080
COLLAB_PORT=1234
LOG_LEVEL=info

# ── Public URLs ───────────────────────────────────────────────────────────────
PUBLIC_MCP_URL=https://api.example.com
MCP_BASE_URL=https://api.example.com
MCP_AUTHORIZATION_SERVER=https://api.example.com
OAUTH_ISSUER=https://api.example.com
WEB_BASE_URL=https://mnema.example.com
PUBLIC_COLLAB_URL=wss://api.example.com/collab
COLLAB_INTERNAL_URL=http://collab:1234
PUBLIC_SITE_URL=https://mnema.example.com
CORS_ORIGINS=https://mnema.example.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=FILL_ME
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://mnema.example.com
JWT_AUDIENCE_MCP=https://api.example.com/mcp

# ── Session + internal secrets (each: openssl rand -hex 32) ───────────────────
# WORKOS_COOKIE_PASSWORD seals WorkOS sessions ONLY (Phase 0 split). The three
# below are loaded by api/collab/workers via env_file and must be present in prod.
WORKOS_COOKIE_PASSWORD=FILL_ME
COLLAB_INTERNAL_SECRET=FILL_ME
SECRETBOX_MASTER_KEY=FILL_ME
API_INTERNAL_SECRET=FILL_ME

# ── WorkOS ────────────────────────────────────────────────────────────────────
WORKOS_CLIENT_ID=FILL_ME
WORKOS_CLIENT_SECRET=FILL_ME
WORKOS_REDIRECT_URI=https://api.example.com/auth/callback
WORKOS_WEBHOOK_SECRET=FILL_ME
FRONTEND_URL=https://mnema.example.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=FILL_ME
EMAIL_FROM=FILL_ME

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=FILL_ME
RAZORPAY_KEY_SECRET=FILL_ME
RAZORPAY_WEBHOOK_SECRET=FILL_ME

# ── AI / Embeddings ───────────────────────────────────────────────────────────
GEMINI_API_KEY=FILL_ME
VOYAGE_AI_API_KEY=FILL_ME
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=128
EMBEDDING_WORKER_CONCURRENCY=2

# ── Autocomplete ──────────────────────────────────────────────────────────────
AUTOCOMPLETE_MODEL=gemini-2.5-flash-lite
AUTOCOMPLETE_DEBOUNCE_MS=350
AUTOCOMPLETE_MAX_PREFIX_CHARS=2000
AUTOCOMPLETE_MAX_SUFFIX_CHARS=500
AUTOCOMPLETE_STOP_SEQUENCES=\n\n
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_USER_PER_DAY=1000
RATE_LIMIT_TENANT_DAILY_UNITS=50000

# ── MCP protocol ─────────────────────────────────────────────────────────────
MCP_PROTOCOL_VERSION=2025-11-25
MCP_ORIGIN_ALLOWLIST=https://mnema.example.com

# ── Cloudflare R2 (DOCX/PDF attachment storage) ───────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=mnema-attachments
R2_PUBLIC_URL=https://pub-xxxx.r2.dev  # public bucket URL for doc images

# ── DOCX/PDF feature ──────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_key_here  # required only for scanned PDF OCR
PDF_RENDER_TIMEOUT_MS=30000
MAX_UPLOAD_SIZE_MB=50

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
