{
  "name": "@boppl/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,collab,workers -c blue,green,magenta \"npm:dev:api\" \"npm:dev:collab\" \"npm:dev:workers\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:collab": "tsx watch src/collab/server.ts",
    "dev:workers": "tsx watch src/workers/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start:collab": "node dist/collab/server.js",
    "start:workers": "node dist/workers/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:round-trip": "vitest run src/tests/round-trip",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "consolidate:domain": "tsx src/scripts/consolidate-domain-workspace.ts",
    "rekey:secretbox": "tsx src/scripts/rekey-secret-box.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.90",
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@boppl/schema": "workspace:*",
    "@boppl/shared": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.0",
    "@hocuspocus/extension-logger": "^4.3.0",
    "@hocuspocus/provider": "^4.3.0",
    "@hocuspocus/server": "^4.3.0",
    "@m2d/md2docx": "^0.0.1",
    "@mistralai/mistralai": "^2.4.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.64.0",
    "@types/mime-types": "^3.0.1",
    "@types/turndown": "^5.0.6",
    "@workos-inc/node": "^10.7.0",
    "ai": "^6.0.221",
    "bullmq": "5.76.8",
    "chart.js": "^4.4.7",
    "diff": "^9.0.0",
    "dompurify": "3.4.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.0",
    "googleapis": "^173.0.0",
    "gpt-tokenizer": "^3.4.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "ioredis": "^5.11.1",
    "iron-session": "^8.0.0",
    "jose": "^5.0.0",
    "juice": "^11.1.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "mdast2docx": "1.6.1",
    "mermaid": "11.16.0",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.16",
    "openai": "^6.45.0",
    "pdfjs-dist": "^6.1.200",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "postgres": "^3.4.0",
    "remark-parse": "^11.0.0",
    "resend": "^6.17.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^11.0.5",
    "voyageai": "^0.4.0",
    "yjs": "^13.6.31",
    "zod": "^3.23.0",
    "@fastify/websocket": "^11.0.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.7",
    "ws": "^8.21.0"
  }
}
