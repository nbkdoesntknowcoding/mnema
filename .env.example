# ── Mnema self-host configuration ────────────────────────────────────────────
# Recommended: run  ./scripts/self-host-init.sh  — it copies this file to .env,
# generates every secret, and derives the URL block for you. To fill it in by
# hand instead: copy to .env and work top-to-bottom; generate each secret with
#   openssl rand -hex 32
#
# Legend — every variable below is labeled:
#   [required]        boot fails (or the feature breaks) without a real value
#   [placeholder ok]  must exist, but the shipped placeholder is valid — it
#                     just keeps that feature off until you set a real value
#   [optional]        safe to leave exactly as-is
#
# NOTE: no inline comments after a value — docker compose env_file treats
# everything after '=' as the value. Comments go on their own line.

# ── Auth ──────────────────────────────────────────────────────────────────────
# [required] 'password' = built-in email+password (recommended for self-host).
# 'oidc' = your own identity provider (also set the OIDC_* block below).
# 'workos' = hosted AuthKit (cloud only — needs real WorkOS credentials).
AUTH_PROVIDER=password
# [required] The web app (Astro) only sees PUBLIC_* vars, and they are baked in
# at BUILD time — keep this mirroring AUTH_PROVIDER, or /auth/local redirects
# to WorkOS. Rebuild the web image after changing it.
PUBLIC_AUTH_PROVIDER=password

# ── Database + cache ──────────────────────────────────────────────────────────
# [optional] Postgres user/db names — the compose defaults match these.
POSTGRES_USER=mnema
# [required] Compose refuses to start without it. Must match DATABASE_URL below.
POSTGRES_PASSWORD=change_me_please
# [optional]
POSTGRES_DB=mnema
# [required] Used by api/collab/workers. Keep user/password/db in sync with the
# three values above (host 'postgres' is the compose service name).
DATABASE_URL=postgresql://mnema:change_me_please@postgres:5432/mnema
# [required] Compose refuses to start without it. Must match REDIS_URL below.
REDIS_PASSWORD=change_me_please
# [required] Keep the password in sync with REDIS_PASSWORD.
REDIS_URL=redis://:change_me_please@redis:6379

# ── Core secrets — all [required], 32+ chars (each: openssl rand -hex 32) ─────
# Seals the session cookie (used in every auth mode, despite the WorkOS name).
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_random_characters
# collab <-> api writeback RPC shared secret.
COLLAB_INTERNAL_SECRET=replace_with_32_plus_random_characters
# KDF seed for at-rest encryption of linked-integration tokens.
SECRETBOX_MASTER_KEY=replace_with_32_plus_random_characters
# web <-> api /_internal/* shared secret.
API_INTERNAL_SECRET=replace_with_32_plus_random_characters
# Signs session JWTs.
JWT_SECRET=replace_with_32_plus_random_characters

# ── URLs (defaults match the docker self-host stack on localhost) ─────────────
# self-host-init.sh derives this whole block from one --url flag; only touch it
# by hand for a custom setup. For a public host, see "Self-host notes" in the
# README — and remember PUBLIC_* values are baked into the web image at build
# time, so changing them means rebuilding the web app.
#
# [required] The api URL. Browser traffic reaches the api through the web's
# same-origin /api proxy (the compose points that at http://api:8080
# internally), so this value is what an MCP client connects to (…/mcp).
PUBLIC_API_URL=http://localhost:8080
# [required] Browser → collab (Yjs/Hocuspocus) WebSocket URL. Local HTTP:
# ws://localhost:1234. HTTPS deploys MUST use wss://<host>/collab via a reverse
# proxy with WebSocket upgrade — ws:// is blocked as mixed content on https
# pages, and localhost:1234 isn't reachable from a remote browser.
PUBLIC_COLLAB_URL=ws://localhost:1234
# [required] Canonical web-app URL — used in invitation links and other
# server-rendered links back into the app.
WEB_BASE_URL=http://localhost:4321
# [required] Same value, web-side (baked at build time).
PUBLIC_SITE_URL=http://localhost:4321
# [required] Comma-separated browser origins allowed on /api/* — include every
# host that serves the web app.
CORS_ORIGINS=http://localhost:4321
# [required] Issuer/audience claims on session JWTs: issuer = the api URL,
# audience = the web URL.
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:4321
# [optional] The hosted service that issues free community licenses (unlocks
# version history + export). The in-app "Get your free community license" form
# posts here — the only outbound call, made only by explicit user action. Leave
# the default to use the maintainer's service; pasted keys are always verified
# offline (airgap-friendly).
PUBLIC_COMMUNITY_LICENSE_URL=https://api.theboringpeople.in/community-license

# ── MCP OAuth server ──────────────────────────────────────────────────────────
# [required] self-host-init.sh generates the RSA keypair; by hand:
#   openssl genpkey -algorithm RSA -out keys/private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# The issuer is the externally-visible api URL (matches PUBLIC_API_URL).
OAUTH_ISSUER=http://localhost:8080
OAUTH_PRIVATE_KEY_PATH=./keys/private.pem
OAUTH_PUBLIC_KEY_PATH=./keys/public.pem

# ── Embeddings + autocomplete (bring your own keys) ───────────────────────────
# [placeholder ok] VOYAGE_API_KEY — voyageai.com, a 1024-dim model. Semantic
# search stays disabled until a real key is set.
VOYAGE_API_KEY=unused_on_self_host
# [placeholder ok] GEMINI_API_KEY — aistudio.google.com. Inline autocomplete
# stays disabled until a real key is set.
GEMINI_API_KEY=unused_on_self_host

# ── Google Drive folder sync (optional; bring your own OAuth app) ──────────────
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console with
# the Drive API enabled, add http://localhost:8080/api/drive/callback as an
# authorised redirect URI, and paste the client id/secret here. Drive stays
# disabled until all three are set. Full setup: docs/connect/drive.md.
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8080/api/drive/callback
# Scope: 'drive.file' (default, least privilege — only files created/opened via
# Mnema) or 'drive' (full — lets users pull pre-existing folders; needs Google's
# restricted-scope review to ship to real users in production).
# GOOGLE_DRIVE_SCOPE=drive.file
# [optional] Skip Drive files larger than this many megabytes (default 50).
# DRIVE_SYNC_MAX_FILE_MB=50

# ── Generic OIDC ──────────────────────────────────────────────────────────────
# [optional] Only read when AUTH_PROVIDER=oidc; discovery runs via the issuer.
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:5173/auth/oidc/callback

# ── Cloud-only integrations (NOT needed for self-host) ────────────────────────
# WorkOS is not needed on self-host — omit it. The vars default to inert
# sentinels and the AUTH_PROVIDER=password|oidc flow never calls WorkOS. (Set
# real values only if you switch AUTH_PROVIDER=workos.)
#
# The open-core (self-host) edition ships with NO payment/billing layer, so
# no RAZORPAY_* variables are required. Leave them unset. (They are declared
# as optional in config/env.ts only so a hosted deployment that layers billing
# on top of core can supply them.)
