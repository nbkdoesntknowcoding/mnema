# ── Mnema self-host configuration ────────────────────────────────────────────
# Copy to .env and fill in. Generate every secret with:  openssl rand -hex 32

# ── Auth ──────────────────────────────────────────────────────────────────────
# 'password' = built-in email+password (recommended for self-host). 'oidc' = your
# own identity provider (set the OIDC_* block). 'workos' = hosted AuthKit (cloud).
AUTH_PROVIDER=password
# The web (Astro) only sees PUBLIC_* vars — mirror it, or /auth/local redirects to WorkOS.
PUBLIC_AUTH_PROVIDER=password

# ── Database + cache ──────────────────────────────────────────────────────────
POSTGRES_USER=mnema
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=mnema
DATABASE_URL=postgresql://mnema:change_me_please@postgres:5432/mnema
REDIS_PASSWORD=change_me_please
REDIS_URL=redis://:change_me_please@redis:6379

# ── Core secrets (each: openssl rand -hex 32) ─────────────────────────────────
# WORKOS_COOKIE_PASSWORD seals the session cookie (used in every auth mode).
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_random_characters
COLLAB_INTERNAL_SECRET=replace_with_32_plus_random_characters
SECRETBOX_MASTER_KEY=replace_with_32_plus_random_characters
API_INTERNAL_SECRET=replace_with_32_plus_random_characters
JWT_SECRET=replace_with_32_plus_random_characters

# ── URLs (defaults match the docker self-host stack; self-host-init.sh sets them) ─
# The docker web listens on :4321 and the api on :8080. Browser → api goes through
# the web's same-origin /api proxy, so PUBLIC_API_URL is only used server-side; the
# compose points the web build at the internal http://api:8080. This value is the
# api URL an MCP client connects to (…/mcp).
PUBLIC_API_URL=http://localhost:8080
# Browser → collab (Yjs/Hocuspocus) WebSocket URL. Local HTTP: ws://localhost:1234.
# HTTPS deploys MUST use wss://<host>/collab via a reverse proxy with WebSocket
# upgrade — ws:// is blocked as mixed-content on https pages, and localhost:1234
# isn't reachable from a remote browser. Rebuild the web app after changing any
# PUBLIC_* var (they're baked in at build time).
PUBLIC_COLLAB_URL=ws://localhost:1234
WEB_BASE_URL=http://localhost:4321
PUBLIC_SITE_URL=http://localhost:4321
CORS_ORIGINS=http://localhost:4321
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:4321
# The hosted service that issues free community licenses (unlocks version history +
# export). The in-app "Get your free community license" form posts here — the only
# outbound call, made only by explicit user action. Leave the default to use the
# maintainer's service; pasted keys are always verified offline (airgap-friendly).
PUBLIC_COMMUNITY_LICENSE_URL=https://api.theboringpeople.in/community-license

# ── MCP OAuth server (an RSA keypair; generate once) ──────────────────────────
#   openssl genpkey -algorithm RSA -out keys/private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
OAUTH_ISSUER=http://localhost:8080
OAUTH_PRIVATE_KEY_PATH=./keys/private.pem
OAUTH_PUBLIC_KEY_PATH=./keys/public.pem

# ── Embeddings + autocomplete (OPTIONAL; bring your own) ──────────────────────
# Read at boot but inert until real keys are set — search + autocomplete stay
# disabled with the placeholder. NOTE: no inline comments below — docker compose
# env_file treats everything after '=' as the value.
# VOYAGE_API_KEY — voyageai.com, a 1024-dim model (semantic search).
VOYAGE_API_KEY=unused_on_self_host
# GEMINI_API_KEY — aistudio.google.com (inline autocomplete).
GEMINI_API_KEY=unused_on_self_host

# ── Generic OIDC (only when AUTH_PROVIDER=oidc) ───────────────────────────────
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:5173/auth/oidc/callback

# ── Cloud-only integrations (NOT needed for self-host) ────────────────────────
# WorkOS is not needed on self-host — omit it. The vars default to inert sentinels
# and the AUTH_PROVIDER=password|oidc flow never calls WorkOS. (Set real values
# only if you switch AUTH_PROVIDER=workos.)
# Hosted billing (Razorpay) is still read at boot — leave these dummy values as-is.
RAZORPAY_KEY_ID=unused_on_self_host
RAZORPAY_KEY_SECRET=unused_on_self_host
RAZORPAY_WEBHOOK_SECRET=unused_on_self_host
